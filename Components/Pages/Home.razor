@page "/"
@rendermode InteractiveServer
@inject NavigationManager Nav
@inject AppDbContext Db
@inject SessionState State
@inject AuthService Auth

<PageTitle>Persona - AI 性格分析师</PageTitle>

<div class="animate-fade-in-up" style="max-width:560px;margin:2rem auto;text-align:center;">

    <div style="font-size:3rem;margin-bottom:0.5rem;">
        <span style="display:inline-block;" class="animate-bounce">🧠</span>
    </div>
    <h2 style="font-size:2rem;margin-bottom:0.25rem;">认识真实的自己</h2>
    <p class="text-muted" style="font-size:1.1rem;margin-bottom:2rem;">
        AI 像朋友一样和你聊天，从对话中读懂你的性格
    </p>

    <div style="display:flex;gap:1rem;justify-content:center;margin-bottom:2rem;">
        <div class="card" style="flex:1;max-width:160px;padding:1.25rem 1rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.25rem;">💬</div>
            <div style="font-size:0.85rem;font-weight:600;">自然对话</div>
            <div style="font-size:0.75rem;color:var(--text-muted);">像朋友一样的聊天</div>
        </div>
        <div class="card" style="flex:1;max-width:160px;padding:1.25rem 1rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.25rem;">📊</div>
            <div style="font-size:0.85rem;font-weight:600;">大五人格+MBTI</div>
            <div style="font-size:0.75rem;color:var(--text-muted);">双重人格分析</div>
        </div>
        <div class="card" style="flex:1;max-width:160px;padding:1.25rem 1rem;text-align:center;">
            <div style="font-size:1.5rem;margin-bottom:0.25rem;">⚡</div>
            <div style="font-size:0.85rem;font-weight:600;">几分钟完成</div>
            <div style="font-size:0.75rem;color:var(--text-muted);">6-8轮对话出结果</div>
        </div>
    </div>

    @if (_username == null)
    {
        <div style="display:flex;gap:1rem;justify-content:center;">
            <a href="/login" class="btn btn-primary btn-lg">开始测试</a>
            <button class="btn btn-outline-secondary btn-lg" @onclick="QuickGuest">游客体验</button>
        </div>
    }
    else
    {
        <p style="margin-bottom:1.5rem;font-size:1.05rem;">👋 你好，<strong>@_username</strong></p>
        <button class="btn btn-primary btn-lg" @onclick="StartTest">开始测试</button>
    }
</div>

@code {
    private string? _username;

    protected override void OnInitialized() => _username = State.Username;

    async Task StartTest()
    {
        var session = new QuizSession();
        Db.Sessions.Add(session);
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/quiz/{session.Id}");
    }

    async Task QuickGuest()
    {
        var r = await Auth.GuestLoginAsync();
        State.Token = r.Token; State.Username = r.Username;
        _username = r.Username;
        StateHasChanged();
    }
}
