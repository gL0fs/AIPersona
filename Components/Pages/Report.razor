@page "/report/{SessionId:int}"
@rendermode InteractiveServer
@inject AppDbContext Db
@inject NavigationManager Nav

<PageTitle>性格分析报告</PageTitle>

@if (_report == null)
{
    <div class="text-center animate-fade-in" style="padding:4rem 0;">
        <div class="spinner-border mb-2" role="status" style="color:var(--accent);"></div>
        <p class="text-muted mt-2">加载中...</p>
    </div>
}
else
{
    <div class="animate-scale-in" style="max-width:640px;margin:0 auto;">

        @* MBTI Hero *@
        <div class="card" style="margin-bottom:2rem;text-align:center;overflow:hidden;">
            <div style="background:linear-gradient(135deg,var(--accent),var(--accent-dark));padding:2rem 1.5rem;color:white;">
                <div style="font-size:0.85rem;opacity:0.8;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem;">你的 MBTI 类型</div>
                <div style="font-size:3.5rem;font-weight:800;letter-spacing:0.15em;">@_report.MbtiType</div>
            </div>
            <div class="card-body">
                <p style="font-size:1.05rem;margin:0;">@_mbtiDesc</p>
            </div>
        </div>

        @* Big Five *@
        <h3 style="margin-bottom:1rem;">大五人格</h3>
        <div style="display:flex;flex-direction:column;gap:0.75rem;margin-bottom:2rem;">
            @foreach (var d in _dims)
            {
                var animDelay = $"{Array.IndexOf(_dims, d) * 80}ms";
                <div class="card animate-fade-in-up" style="animation-delay:@animDelay;">
                    <div class="card-body" style="padding:1rem 1.25rem;">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span style="font-weight:600;">@d.Label</span>
                            <span style="font-weight:700;font-size:1.1rem;color:@d.BarColor;">@d.Value</span>
                        </div>
                        <div class="progress" style="height:8px;">
                            <div class="progress-bar" style="width:@d.Value%;background:@d.BarColor;transition:width 1.5s cubic-bezier(0.4,0,0.2,1);"></div>
                        </div>
                        <div style="font-size:0.8rem;color:var(--text-muted);margin-top:0.4rem;">@d.Desc</div>
                    </div>
                </div>
            }
        </div>

        @* Summary *@
        <div class="card animate-fade-in-up" style="margin-bottom:2rem;">
            <div class="card-header">📝 AI 生成的人格画像</div>
            <div class="card-body">
                <p style="line-height:1.8;font-size:1rem;margin:0;">@_report.Summary</p>
            </div>
        </div>

        <div style="display:flex;gap:1rem;justify-content:center;">
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/")'>重新测试</button>
            <a href="/history" class="btn btn-outline-secondary">历史记录</a>
        </div>
    </div>
}

@code {
    [Parameter] public int SessionId { get; set; }
    private ReportResponse? _report;
    private string _mbtiDesc = "";
    private (string Label, string BarColor, string Desc, int Value)[] _dims = Array.Empty<(string,string,string,int)>();

    protected override async Task OnInitializedAsync()
    {
        var session = await Db.Sessions.FindAsync(SessionId);
        if (session?.ReportJson == null) { Nav.NavigateTo("/"); return; }

        _report = System.Text.Json.JsonSerializer.Deserialize<ReportResponse>(session.ReportJson,
            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        if (_report == null) { Nav.NavigateTo("/"); return; }

        _dims = new[] {
            ("开放性", "#7c3aed", "想象力、好奇心、审美敏感度", _report.Openness),
            ("尽责性", "#10b981", "自律、条理、成就动机", _report.Conscientiousness),
            ("外向性", "#f59e0b", "社交能量、活力、积极情绪", _report.Extraversion),
            ("宜人性", "#3b82f6", "同理心、合作精神、利他倾向", _report.Agreeableness),
            ("神经质", "#ef4444", "情绪敏感度（低分则情绪稳定）", _report.Neuroticism),
        };

        _mbtiDesc = _report.MbtiType switch
        {
            "INTJ" => "建筑师——独立、战略性的思考者","INTP" => "逻辑学家——创新、好奇的分析者",
            "ENTJ" => "指挥官——果断、有远见的领导者","ENTP" => "辩论家——机智、有创造力的思想者",
            "INFJ" => "提倡者——安静而富有远见的理想家","INFP" => "调停者——忠于价值观的理想主义者",
            "ENFJ" => "主人公——富有魅力的激励者","ENFP" => "竞选者——热情、爱社交的自由精神",
            "ISTJ" => "物流师——务实、可靠、有条不紊","ISFJ" => "守卫者——细心、有奉献精神的保护者",
            "ESTJ" => "总经理——高效、有组织的管理者","ESFJ" => "执行官——热心、有责任感的维护者",
            "ISTP" => "鉴赏家——务实、灵活的动手者","ISFP" => "探险家——温和、敏感的艺术家",
            "ESTP" => "企业家——精力充沛的冒险者","ESFP" => "表演者——自发性强、热爱生活的娱乐者",
            _ => "独特的混合型人格"
        };
    }
}
