@page "/login"
@rendermode InteractiveServer
@inject AuthService Auth
@inject NavigationManager Nav
@inject SessionState State

<PageTitle>登录 - Persona</PageTitle>

<div class="animate-fade-in-up" style="max-width:420px;margin:3rem auto;">
    <div style="text-align:center;margin-bottom:2rem;">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">🧠</div>
        <h2 style="margin-bottom:0.25rem;">Persona</h2>
        <p class="text-muted">AI 性格分析师</p>
    </div>

    <div class="card" style="padding:0.25rem;">
        <div class="card-body">
            @if (_mode == "login")
            {
                <h5 style="font-weight:700;margin-bottom:1rem;">登录</h5>
                <div class="mb-3"><input @bind="_username" class="form-control" placeholder="用户名" /></div>
                <div class="mb-3"><input @bind="_password" type="password" class="form-control" placeholder="密码" /></div>
                @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger py-2" style="font-size:0.9rem;border-radius:10px;">@_error</div> }
                <button class="btn btn-primary w-100 mb-3" @onclick="DoLogin">登录</button>
                <div class="text-center" style="font-size:0.9rem;">
                    <a href="javascript:void(0)" @onclick='() => { _mode = "register"; _error = ""; }'>没有账号？注册</a>
                </div>
            }
            else
            {
                <h5 style="font-weight:700;margin-bottom:1rem;">注册</h5>
                <div class="mb-3"><input @bind="_username" class="form-control" placeholder="用户名" /></div>
                <div class="mb-3"><input @bind="_password" type="password" class="form-control" placeholder="密码" /></div>
                @if (!string.IsNullOrEmpty(_error)) { <div class="alert alert-danger py-2" style="font-size:0.9rem;border-radius:10px;">@_error</div> }
                <button class="btn btn-primary w-100 mb-3" @onclick="DoRegister">注册</button>
                <div class="text-center" style="font-size:0.9rem;">
                    <a href="javascript:void(0)" @onclick='() => { _mode = "login"; _error = ""; }'>已有账号？登录</a>
                </div>
            }
        </div>
    </div>

    <div class="text-center mt-3">
        <button class="btn btn-outline-secondary" @onclick="GuestLogin">以游客身份体验</button>
    </div>
</div>

@code {
    private string _mode = "login";
    private string _username = "", _password = "", _error = "";

    async Task DoLogin()
    {
        try { _error = ""; var r = await Auth.LoginAsync(_username, _password); State.Token = r.Token; State.Username = r.Username; Nav.NavigateTo("/"); }
        catch (Exception ex) { _error = ex.Message; }
    }
    async Task DoRegister()
    {
        try { _error = ""; var r = await Auth.RegisterAsync(_username, _password); State.Token = r.Token; State.Username = r.Username; Nav.NavigateTo("/"); }
        catch (Exception ex) { _error = ex.Message; }
    }
    async Task GuestLogin()
    {
        var r = await Auth.GuestLoginAsync(); State.Token = r.Token; State.Username = r.Username; Nav.NavigateTo("/");
    }
}
